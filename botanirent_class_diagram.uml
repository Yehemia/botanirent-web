@startuml BotaniRent_Class_Diagram

title Class Diagram BotaniRent - BCE Pattern
footer Proyek BotaniRent | Boundary-Control-Entity Pattern

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classFontStyle bold
skinparam classBackgroundColor<<Boundary>> #EBF5FB
skinparam classBorderColor<<Boundary>> #2980B9
skinparam classBackgroundColor<<Controller>> #E8F8F5
skinparam classBorderColor<<Controller>> #117A65
skinparam classBackgroundColor<<Entity>> #FEF9E7
skinparam classBorderColor<<Entity>> #D35400
skinparam packageBackgroundColor #FAFAFA
skinparam packageBorderColor #CCCCCC
skinparam linetype ortho

' ============================================================
' MODUL 1: POS & TRANSAKSI
' ============================================================
package "Modul POS & Transaksi" {

    class POSView <<Boundary>> {
        - searchBar : SearchBar
        - catalogGrid : Grid
        - btnAddToCart : Button
        - cartTable : Table
        - btnCheckout : Button
        - customerSelector : Select
        - rentalDateModal : Modal
        - paymentModal : Modal
        + handleAddToCart(item : Object) : void
        + handleRemoveFromCart(itemId : uuid) : void
        + handleCheckout(formData : FormData) : void
    }

    class POSController <<Controller>> {
        - categoryModel : Object
        - itemModel : Object
        - packageModel : Object
        - customerModel : Object
        - settingsModel : Object
        - transactionModel : Object
        - activityLogModel : Object
        + getPOSData(profile : Object) : Object
        + getCheckoutData(profile : Object) : Object
        + checkout(profile : Object, formData : FormData, config : Object) : Object
    }

    class TransactionModel <<Entity>> {
        - transactionsTable : String
        - transactionItemsTable : String
        - id : uuid
        - branch_id : uuid
        - cashier_id : uuid
        - customer_id : uuid
        - transaction_code : String
        - type : String
        - subtotal : numeric
        - discount_amount : numeric
        - discount_percent : numeric
        - total_amount : numeric
        - paid_amount : numeric
        - change_amount : numeric
        - payment_method : String
        - payment_status : String
        - midtrans_transaction_id : String
        - midtrans_snap_token : String
        - item_name : String
        - quantity : int
        - unit_price : numeric
        - rental_start_date : date
        - rental_end_date : date
        - rental_days : int
        - rental_status : String
        - returned_at : timestamptz
        - return_condition : String
        - return_notes : String
        + checkoutTransaction(payload : Object) : Object
        + getTransactionDetails(id : uuid) : Object
        + getTransactionsHistory(branchId : uuid) : Array
        + updateTransaction(id : uuid, data : Object) : Object
        + getActiveRentalsForReturns(branchId : uuid) : Array
        + updateTransactionItem(id : uuid, data : Object) : Object
    }

    class CustomerModel <<Entity>> {
        - customersTable : String
        - id : uuid
        - branch_id : uuid
        - full_name : String
        - phone : String
        - email : String
        - address : String
        - notes : String
        - created_at : timestamptz
        + getCustomers(branchId : uuid) : Array
        + getCustomersMinimal(branchId : uuid) : Array
        + createCustomer(customerData : Object) : Object
        + getCustomerDetails(id : uuid) : Object
    }

    POSView ..> POSController : uses
    POSController --> TransactionModel : delegates
    POSController --> CustomerModel : delegates
    TransactionModel ..> CustomerModel : associates with
}

' ============================================================
' MODUL 2: PENGEMBALIAN & DENDA
' ============================================================
package "Modul Pengembalian & Denda" {

    class ReturnsView <<Boundary>> {
        - invoiceInput : TextField
        - btnSearch : Button
        - rentalsTable : Table
        - btnReturnItems : Button
        - returnModal : Modal
        - btnConfirmReturn : Button
        + handleSearchTransaction(code : String) : void
        + handleProcessReturn(payload : Object) : void
    }

    class PenaltiesView <<Boundary>> {
        - rulesTable : Table
        - btnUpdateRule : Button
        - ruleModal : Modal
        - inputAmount : TextField
        - btnSaveRule : Button
        + handleUpdateRule(ruleId : uuid, amount : numeric) : void
    }

    class ReturnsController <<Controller>> {
        - transactionModel : Object
        - penaltyModel : Object
        - settingsModel : Object
        - bookingModel : Object
        - assetModel : Object
        - activityLogModel : Object
        + getReturnsPageData(profile : Object) : Object
        + processReturn(profile : Object, formData : FormData) : Object
    }

    class PenaltiesController <<Controller>> {
        - penaltyModel : Object
        - activityLogModel : Object
        + getPenaltyRules(profile : Object) : Object
        + updatePenaltyRule(profile : Object, formData : FormData) : Object
    }

    class PenaltyModel <<Entity>> {
        - penaltiesTable : String
        - penaltyRulesTable : String
        - id : uuid
        - transaction_item_id : uuid
        - penalty_rule_id : uuid
        - branch_id : uuid
        - type : String
        - late_days : int
        - calculated_amount : numeric
        - payment_status : String
        - notes : String
        - paid_at : timestamptz
        - rule_name : String
        - rule_calculation_method : String
        - rule_amount : numeric
        + getPenaltyRules() : Array
        + getPenalties(branchId : uuid) : Array
        + insertPenalty(penaltyData : Object) : Object
        + updatePenaltyRule(id : uuid, amount : numeric) : Object
    }

    ReturnsView ..> ReturnsController : uses
    PenaltiesView ..> PenaltiesController : uses
    ReturnsController --> PenaltyModel : delegates
    PenaltiesController --> PenaltyModel : delegates
}

' ============================================================
' MODUL 3: INVENTARIS & PAKET
' ============================================================
package "Modul Inventaris & Paket" {

    class InventoryView <<Boundary>> {
        - itemsTable : Table
        - btnAddNewItem : Button
        - itemModal : Modal
        - inputItemName : TextField
        - inputBarcode : TextField
        - btnSaveItem : Button
        + handleSaveItem(formData : FormData) : void
        + handleDeleteItem(id : uuid) : void
    }

    class PackagesView <<Boundary>> {
        - packagesTable : Table
        - btnCreatePackage : Button
        - packageModal : Modal
        - inputPackageName : TextField
        - btnSavePackage : Button
        + handleSavePackage(formData : FormData) : void
        + handleDeletePackage(id : uuid) : void
    }

    class ItemController <<Controller>> {
        - itemModel : Object
        - categoryModel : Object
        - activityLogModel : Object
        + getItems(profile : Object) : Object
        + getItemDetails(id : uuid) : Object
        + saveItem(profile : Object, formData : FormData) : Object
        + deleteItem(id : uuid) : Object
    }

    class PackageController <<Controller>> {
        - packageModel : Object
        - itemModel : Object
        - activityLogModel : Object
        + getPackages(profile : Object) : Object
        + savePackage(profile : Object, formData : FormData) : Object
        + deletePackage(id : uuid) : Object
    }

    class ItemModel <<Entity>> {
        - itemsTable : String
        - id : uuid
        - branch_id : uuid
        - category_id : uuid
        - name : String
        - description : String
        - barcode : String
        - rental_price_per_day : numeric
        - sell_price : numeric
        - stock_total : int
        - stock_available : int
        - is_active : boolean
        - category_name : String
        - category_type : String
        + getItems(branchId : uuid) : Array
        + getActiveSewaItems(branchId : uuid) : Array
        + getActiveItems(branchId : uuid) : Array
        + getItemDetails(id : uuid) : Object
        + insertItem(itemData : Object) : Object
        + updateItem(id : uuid, itemData : Object) : Object
        + deleteItem(id : uuid) : boolean
        + bulkInsertItems(itemsList : Array) : boolean
    }

    class CategoryModel <<Entity>> {
        - categoriesTable : String
        - id : uuid
        - name : String
        - type : String
        - is_active : boolean
        + getCategories(branchId : uuid) : Array
        + insertCategory(categoryData : Object) : Object
        + updateCategory(id : uuid, categoryData : Object) : Object
        + deleteCategory(id : uuid) : boolean
    }

    class PackageModel <<Entity>> {
        - packagesTable : String
        - packageItemsTable : String
        - id : uuid
        - branch_id : uuid
        - name : String
        - description : String
        - image_url : String
        - package_price : numeric
        - is_active : boolean
        - item_quantity : int
        + getPackages(branchId : uuid) : Array
        + getActivePackages(branchId : uuid) : Array
        + getPackageDetails(id : uuid) : Object
        + createPackage(data : Object, items : Array) : Object
        + updatePackage(id : uuid, data : Object, items : Array) : Object
        + deletePackage(id : uuid) : boolean
    }

    InventoryView ..> ItemController : uses
    PackagesView ..> PackageController : uses
    ItemController --> ItemModel : delegates
    ItemController --> CategoryModel : delegates
    PackageController --> PackageModel : delegates
    PackageModel --> ItemModel : references
}

' ============================================================
' MODUL 4: ASET FISIK & BOOKING
' ============================================================
package "Modul Aset Fisik & Booking" {

    class AssetStatusView <<Boundary>> {
        - searchInput : TextField
        - kanbanGrid : Grid
        - btnUpdateStatus : Button
        - statusBadge : Label
        + handleUpdateStatus(assetId : uuid, status : String) : void
        + getAssetsByStatus(status : String) : Array
    }

    class BookingView <<Boundary>> {
        - calendar : Calendar
        - btnBlockMaintenance : Button
        - maintenanceModal : Modal
        - dateRangePicker : DateRangePicker
        - btnSaveBlock : Button
        + handleCreateBlock(formData : FormData) : void
        + handleCancelBlock(id : uuid) : void
    }

    class AssetStatusController <<Controller>> {
        - assetModel : Object
        + getAssets(profile : Object) : Object
        + updateStatus(profile : Object, formData : FormData) : Object
    }

    class BookingController <<Controller>> {
        - bookingModel : Object
        - categoryModel : Object
        - itemModel : Object
        - assetModel : Object
        - branchModel : Object
        - activityLogModel : Object
        + getBookingPageData(profile : Object, searchBranchId : uuid) : Object
        + createMaintenance(profile : Object, formData : FormData) : Object
        + deleteBooking(profile : Object, formData : FormData) : Object
    }

    class AssetModel <<Entity>> {
        - rentalAssetsTable : String
        - id : uuid
        - item_id : uuid
        - asset_code : String
        - status : String
        - notes : String
        - last_status_change : timestamptz
        + getAssetsStatusCounts(branchId : uuid) : Object
        + getAssets(params : Object) : Array
        + updateAssetStatus(id : uuid, status : String, notes : String) : Object
        + deleteMaintenanceBookingForAsset(assetId : uuid) : boolean
        + getReadyAssetsForItem(itemId : uuid) : Array
        + insertAssets(assetsList : Array) : boolean
    }

    class BookingModel <<Entity>> {
        - bookingsTable : String
        - id : uuid
        - rental_asset_id : uuid
        - transaction_item_id : uuid
        - branch_id : uuid
        - start_date : date
        - end_date : date
        - status : String
        + getBranchBookings(branchId : uuid) : Array
        + createBooking(bookingData : Object) : Object
        + getBookingDetails(id : uuid) : Object
        + deleteBooking(id : uuid) : boolean
        + updateBookingStatusByTransactionItem(transactionItemId : uuid, status : String) : boolean
    }

    AssetStatusView ..> AssetStatusController : uses
    BookingView ..> BookingController : uses
    AssetStatusController --> AssetModel : delegates
    BookingController --> BookingModel : delegates
    BookingController --> AssetModel : delegates
    BookingModel --> AssetModel : references
}

' ============================================================
' MODUL 5: PENGGUNA, CABANG, & AUDIT TRAIL
' ============================================================
package "Modul Pengguna, Cabang, & Audit Trail" {

    class BranchManagementView <<Boundary>> {
        - branchesTable : Table
        - btnCreateBranch : Button
        - branchModal : Modal
        - inputBranchName : TextField
        - btnSaveBranch : Button
        + handleSaveBranch(formData : FormData) : void
        + handleDeleteBranch(id : uuid) : void
    }

    class ActivityLogView <<Boundary>> {
        - logsTable : Table
        - branchSelector : Select
        - searchInput : TextField
        + handleFilter() : void
    }

    class BranchController <<Controller>> {
        - branchModel : Object
        + getBranches() : Object
        + saveBranch(id : uuid, formData : FormData) : Object
        + deleteBranch(id : uuid) : Object
    }

    class ActivityLogController <<Controller>> {
        - activityLogModel : Object
        - branchModel : Object
        + getActivityLogData(profile : Object, searchParams : URLSearchParams) : Object
    }

    class BranchModel <<Entity>> {
        - branchesTable : String
        - id : uuid
        - name : String
        - address : String
        - phone : String
        - is_active : boolean
        - created_at : timestamptz
        + getBranches() : Array
        + insertBranch(branchData : Object) : Object
        + updateBranch(id : uuid, branchData : Object) : Object
        + deleteBranch(id : uuid) : boolean
    }

    class ActivityLogModel <<Entity>> {
        - activityLogsTable : String
        - id : uuid
        - user_id : uuid
        - branch_id : uuid
        - action : String
        - entity_type : String
        - entity_id : uuid
        - metadata : jsonb
        - created_at : timestamptz
        + getActivityLogs(filter : Object) : Object
        + logActivity(logData : Object) : Object
    }

    BranchManagementView ..> BranchController : uses
    ActivityLogView ..> ActivityLogController : uses
    BranchController --> BranchModel : delegates
    ActivityLogController --> ActivityLogModel : delegates
    ActivityLogModel --> BranchModel : references
}

' ============================================================
' MODUL 6: LAPORAN, STATISTIK, & PENGATURAN
' ============================================================
package "Modul Laporan, Statistik, & Pengaturan" {

    class DashboardView <<Boundary>> {
        - kpiCards : Card[]
        - revenueChart : Chart
        - branchChart : Chart
        - recentTrxTable : Table
        - monthSelector : Select
        + handleRefresh() : void
    }

    class SettingsView <<Boundary>> {
        - inputDefaultDuration : TextField
        - inputLateFee : TextField
        - inputTargetRevenue : TextField
        - btnSaveSettings : Button
        + handleSaveSettings(formData : FormData) : void
    }

    class DashboardController <<Controller>> {
        - transactionModel : Object
        - itemModel : Object
        - settingsModel : Object
        - branchModel : Object
        + getDashboardData(profile : Object) : Object
    }

    class SettingsController <<Controller>> {
        - settingsModel : Object
        + getRentalSettings() : Object
        + updateRentalSettings(profile : Object, formData : FormData) : Object
    }

    class SettingsModel <<Entity>> {
        - settingsTable : String
        - key : String
        - value : jsonb
        - updated_at : timestamptz
        + getRentalSettings() : Object
        + upsertRentalSettings(value : Object) : boolean
    }

    DashboardView ..> DashboardController : uses
    SettingsView ..> SettingsController : uses
    DashboardController --> SettingsModel : delegates
    SettingsController --> SettingsModel : delegates
}

' ============================================================
' RELASI ANTAR MODUL (Cross-Module Relationships)
' ============================================================

' POS menggunakan entity dari modul lain
POSController --> ItemModel : delegates
POSController --> PackageModel : delegates
POSController --> CategoryModel : delegates
POSController --> SettingsModel : delegates
POSController --> ActivityLogModel : delegates

' Returns menggunakan entity dari modul lain
ReturnsController --> TransactionModel : delegates
ReturnsController --> BookingModel : delegates
ReturnsController --> AssetModel : delegates
ReturnsController --> SettingsModel : delegates
ReturnsController --> ActivityLogModel : delegates

' Penalties menggunakan entity dari modul lain
PenaltiesController --> ActivityLogModel : delegates

' Booking menggunakan entity dari modul lain
BookingController --> CategoryModel : delegates
BookingController --> ItemModel : delegates
BookingController --> BranchModel : delegates
BookingController --> ActivityLogModel : delegates

' Dashboard menggunakan entity dari modul lain
DashboardController --> TransactionModel : delegates
DashboardController --> ItemModel : delegates
DashboardController --> BranchModel : delegates

' Entity-to-Entity relationships
TransactionModel --> ItemModel : references
AssetModel --> ItemModel : references
BookingModel --> TransactionModel : references

' Legend
legend right
  |= Warna |= Stereotype |= Deskripsi |
  | <#EBF5FB> | <<Boundary>> | UI View (Svelte +page.svelte) |
  | <#E8F8F5> | <<Controller>> | Business Logic (controllers/) |
  | <#FEF9E7> | <<Entity>> | Data Model (models/) |
  ---
  Atribut: visibilitas private (-)
  Method: visibilitas public (+)
  Relasi: ..> uses, --> delegates/references
endlegend

@enduml
