{
	"name": "botanirent-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:setup": "node tests/setup-test-db.js",
		"test:cleanup": "node tests/cleanup-test-db.js",
		"test:e2e": "npm run test:setup && playwright test && npm run test:cleanup",
		"test:e2e:ui": "npm run test:setup && playwright test --ui",
		"prebuild": "node tests/prebuild.js"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"dotenv": "^17.4.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@lucide/svelte": "^1.16.0",
		"@supabase/ssr": "^0.10.3",
		"@supabase/supabase-js": "^2.106.1",
		"chart.js": "^4.5.1",
		"date-fns": "^4.2.1",
		"svelte-chartjs": "^4.0.1",
		"svelte-sonner": "^1.1.1",
		"xlsx": "^0.18.5",
		"zod": "^4.4.3"
	}
}
